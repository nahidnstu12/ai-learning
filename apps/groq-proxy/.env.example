# Required — never commit real keys
GROQ_API_KEY=

# Comma-separated browser origins allowed to call this API (your deployed chat URL).
# Empty = allow all origins (ok for local dev; set in production).
ALLOWED_ORIGINS=https://your-demo.example.com,https://www.your-demo.example.com

# Per-IP sliding window (default 60s / 30 req)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Hard cap on Groq max_tokens (client can request lower)
MAX_TOKENS_CAP=512

# Max messages array length
MAX_MESSAGES=200

PORT=8787
