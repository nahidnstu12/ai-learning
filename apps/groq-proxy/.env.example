# Required — never commit real keys
GROQ_API_KEY=

# CORS: unset, `*`, or `all` = allow any origin (demo only — anyone can use your proxy from a browser).
# Otherwise comma-separated allowlist, e.g. https://interview-chat.bynarilab.com
# ALLOWED_ORIGINS=*

# Per-IP sliding window (default 60s / 30 req)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Hard cap on Groq max_tokens (client can request lower)
MAX_TOKENS_CAP=512

# Max messages array length
MAX_MESSAGES=200

PORT=8787
