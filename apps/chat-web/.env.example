# Dev: Vite proxy (see vite.config.js) — avoids CORS
VITE_OLLAMA_URL=/ollama

# --- Groq (OpenAI-compatible) —
# Prefer this: key is read by the Vite dev server only (not bundled). Browser calls `/groq/chat/completions`.
GROQ_API_KEY=

# Fallback name also supported by vite.config proxy:
# VITE_GROQ_API_KEY=

# Groq model id (default llama-3.1-70b-versatile). Set VITE_DISABLE_GROQ=1 to hide Groq in the route dropdown.
# VITE_GROQ_MODEL=llama-3.1-70b-versatile

# Optional: direct browser → Groq (key must be VITE_GROQ_API_KEY; CORS may apply). Leave unset to use dev proxy.
# VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1

# VITE_GROQ_TEMPERATURE=0.7

# Or direct (set OLLAMA_ORIGINS on Ollama for your dev origin)
# VITE_OLLAMA_URL=http://127.0.0.1:11434

# Default when only one model (also used if VITE_MODEL_CHAT_OPTIONS is empty)
VITE_MODEL_CHAT=phi3

# Comma-separated = toolbar switcher; each id must appear in `ollama list`
# VITE_MODEL_CHAT_OPTIONS=phi3,llama3.2:1b

# Estimated prompt token budget for context pipeline (lower = eviction/compress sooner). Default in code: 8192.
# VITE_CONTEXT_TOKEN_BUDGET=4096

# Optional — match chat-cli style
# VITE_CHAT_SYSTEM_PROMPT=You are a helpful, concise assistant.
# VITE_CHAT_NUM_PREDICT=512
# VITE_CHAT_TEMPERATURE=0.7
# VITE_CHAT_TOP_P=0.9
# VITE_CHAT_TOP_K=40
# VITE_CHAT_REPEAT_PENALTY=1.1
# VITE_OLLAMA_KEEP_ALIVE=5m
